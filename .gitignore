# =============================================================================
# Root .gitignore for Water Quality Monitoring Monorepo
# =============================================================================

# =============================================================================
# Maven / Java Build Artifacts
# =============================================================================
target/
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
pom.xml.versionsBackup
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# =============================================================================
# Node.js / Vite / Frontend Build Artifacts
# =============================================================================
node_modules/
dist/
build/
.cache/
.vite/
.npm/
.yarn/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.local

# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.local
.env.*.local
.env.production
.env.development

# =============================================================================
# IDE / Editor Files
# =============================================================================
# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache
bin/
!**/src/main/**/bin/
!**/src/test/**/bin/

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# VS Code
.vscode/
*.code-workspace

# Cursor
.cursor/

# =============================================================================
# Operating System Files
# =============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# =============================================================================
# Logs
# =============================================================================
logs/
*.log
*.log.*
log/

# =============================================================================
# Service Management (from scripts/)
# =============================================================================
scripts/.service-pids
scripts/logs/

# =============================================================================
# Database Files
# =============================================================================
# SQLite database files (uncomment if you want to ignore all .db files)
# Note: Some .db files may be needed for demo/seed data
# *.db
# *.sqlite
# *.sqlite3

# SQLite temporary files (always ignore)
*.db-shm
*.db-wal
*.db-journal

# MongoDB
*.mongodb

# =============================================================================
# Temporary Files
# =============================================================================
*.tmp
*.temp
*.swp
*.swo
*~
.cache/
tmp/
temp/

# =============================================================================
# Test Coverage
# =============================================================================
.nyc_output/
coverage/
*.lcov
.coveralls.yml

# =============================================================================
# Package Manager Lock Files (optional - uncomment if you want to ignore)
# =============================================================================
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# =============================================================================
# Build Tools
# =============================================================================
.gradle/
.gradle-wrapper/
build/
out/

# =============================================================================
# Docker (if used later)
# =============================================================================
.dockerignore
docker-compose.override.yml

# =============================================================================
# Miscellaneous
# =============================================================================
*.bak
*.backup
*.orig
*.rej
*.pyc
__pycache__/
.pytest_cache/
.mypy_cache/

# Application specific
# Keep data directories but ignore large files
data/images/*
!data/images/.gitkeep
# Uncomment if you want to ignore all database files in data directories
# data/*.db

